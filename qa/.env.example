# qa/.env — copy to .env and fill in per-client values
# This file is committed as an example. qa/.env is gitignored.

# Live site URL (from client.json → SITE_URL)
BASE_URL=https://yourclientdomain.com

# Test user — created once in Supabase Auth dashboard (role: client)
TEST_EMAIL=qa-test@example.com
TEST_PASSWORD=changeme

# Master admin user — role: master (full access)
TEST_MASTER_EMAIL=master@example.com
TEST_MASTER_PASSWORD=changeme

# Staff user — role: staff (own data only). Leave blank to skip staff role tests.
TEST_STAFF_EMAIL=
TEST_STAFF_PASSWORD=
